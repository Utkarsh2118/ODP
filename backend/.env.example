PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/online-donation-platform
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=7d
ADMIN_BOOTSTRAP_SECRET=set_a_bootstrap_secret_for_admin_creation
# Get Razorpay test credentials from https://dashboard.razorpay.com/app/keys
# Test credentials start with: rzp_test_* for key ID
RAZORPAY_KEY_ID=rzp_test_your_actual_key_id
RAZORPAY_KEY_SECRET=your_actual_key_secret

# SMTP configuration for forgot-password OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
MAIL_FROM=DonateSphere <your_email@gmail.com>

CLIENT_URL=http://127.0.0.1:5500
